# HTTP API
HTTP_PORT=8080

# PostgreSQL for docker compose
POSTGRES_DB=rooms
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5433

# App database connection
DATABASE_URL=postgres://postgres:postgres@db:5432/rooms?sslmode=disable
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5433/rooms?sslmode=disable

# JWT signing key for local development
JWT_SECRET=change-me-local-jwt-secret

# Slot materialization horizon in days
SLOT_HORIZON_DAYS=7

# Conference mock service
CONFERENCE_SERVICE_URL=http://conference-mock:8090
CONFERENCE_TIMEOUT_MS=1500
CONFERENCE_MOCK_PORT=8090
CONFERENCE_MOCK_FAIL_RATE=0

# Fixed users for /dummyLogin
DUMMY_ADMIN_USER_ID=11111111-1111-1111-1111-111111111111
DUMMY_USER_USER_ID=22222222-2222-2222-2222-222222222222